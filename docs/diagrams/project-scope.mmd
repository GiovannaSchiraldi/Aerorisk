%%      UC-02  Log Out
%%      UC-03  Update Profile
%%      UC-08  Export PDF Report
%%  All other UCs are shown so the full team contribution
%%  and project scope are visible in one picture.
%% =========================================================

    Engineer(("Engineer")):::actor
    Admin(("Admin")):::actor

    Admin -. "generalizes" .-> Engineer

    subgraph AeroRisk["AeroRisk  —  PRA Web Platform  (System Boundary)"]
        direction TB

        subgraph Auth["Authentication and Account Management"]
            direction TB
            UC01(["UC-01
            Log In
            (owner: Rodrigo — Backend)"]):::team
            UC02(["UC-02
            Log Out
            (owner: Giovanna — Testing and Docs)"]):::mine
            UC03(["UC-03
            Update Profile
            (owner: Rodrigo — Backend)"]):::mine
        end

        subgraph Modeling["Project Creation and Fault-Tree Modeling"]
            direction TB
            UC04(["UC-04
            Create Project
            (owner: Uriel — Frontend)"]):::team
            UC09(["UC-09
            Load NASA Template
            (owner: Giovanna — Testing and Docs)"]):::team
            UC05(["UC-05
            Build Fault Tree
            (owners: Uriel — Frontend  and  Jada — Fault-Tree Engine)"]):::team
        end

        subgraph Analysis["Risk Simulation and Reporting"]
            direction TB
            UC06(["UC-06
            Run Simulation
            (owner: Daniel — Monte Carlo)"]):::team
            UC07(["UC-07
            View Results
            (owners: Daniel — Monte Carlo  and  Luna — Integration)"]):::team
            UC08(["UC-08
            Export PDF Report
            (owner: Luna — Integration)"]):::mine
        end

        subgraph AdminBlock["System Administration"]
            direction TB
            UC10(["UC-10
            Manage Users
            (owner: Luna — Integration)"]):::team
        end
