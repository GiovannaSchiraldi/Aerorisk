    %% ---------- Actor associations ----------
    Engineer --- UC01
    Engineer --- UC02
    Engineer --- UC03
    Engineer --- UC04
    Engineer --- UC05
    Engineer --- UC06
    Engineer --- UC07
    Engineer --- UC08
    Engineer --- UC09
    Admin    --- UC10

    %% ---------- UML relationships between use cases ----------
    UC04 -. "«include»" .-> UC09
    UC06 -. "«include»" .-> UC05
    UC07 -. "«include»" .-> UC06
    UC08 -. "«extend»"  .-> UC07
    UC02 -. "«related»" .-> UC01
    UC03 -. "«related»" .-> UC10

    %% ---------- Legend ----------
    subgraph Legend[" Legend "]
        direction LR
        L1[/"Highlighted = author's use cases (UC-02, UC-03, UC-08)"/]:::mine
        L2[/"Team-owned use case (other group members)"/]:::team
        L3(("Actor")):::actor
        L4[/"«include» = required sub-behavior     «extend» = optional sub-behavior"/]:::note
    end

